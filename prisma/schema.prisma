// ============================================================
//  Prisma Schema -- The Teneen (Egyptian MyFitnessPal)
//  Full schema with all feature models
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Existing Models (Preserved) ─────────────────────────────

model Restaurant {
  id        String           @id @default(uuid())
  name      String           @unique
  category  String
  rating    Float            @default(4.6)
  items     CachedMenuItem[]
  addOns    CachedAddOn[]
  createdAt DateTime         @default(now())
}

model CachedMenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  itemName     String

  caloriesMin  Int
  caloriesMax  Int
  proteinMin   Int
  proteinMax   Int
  carbsMin     Int
  carbsMax     Int
  fatsMin      Int
  fatsMax      Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, itemName])
}

model CachedAddOn {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  addOnName    String
  calories     Int
  protein      Int
  carbs        Int
  fats         Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, addOnName])
}

model Company {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKey])
}

// -- User (Extended with full profile) ----------------------

model User {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  passwordHash     String

  // Physical profile
  age              Int?
  weightKg         Float?
  heightCm         Float?
  gender           String?     // male | female
  activityLevel    String      @default("moderate") // sedentary | lightly_active | moderate | very_active
  goal             String      @default("maintain") // lose | maintain | gain

  // Daily goals
  dailyCalorieGoal Int         @default(2000)
  proteinGoal      Int         @default(150)
  carbsGoal        Int         @default(200)
  fatsGoal         Int         @default(65)
  dailyWaterGoalMl Int         @default(2500)

  // App settings
  language         String      @default("en") // en | ar
  isPremium        Boolean     @default(false)
  isActive         Boolean     @default(true)

  // Relations
  mealLogs         MealLog[]
  foodLogs         FoodLog[]
  waterLogs        WaterLog[]
  weightLogs       WeightLog[]
  mealPlans        MealPlan[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([email])
}

// -- Meal Log (AI-analyzed restaurant meals) -----------------

model MealLog {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantName       String
  mealName             String
  imageUrl             String?

  calories             Float
  protein              Float
  carbs                Float
  fats                 Float

  ingredientsBreakdown Json
  rawAiResponse        Json?

  source               String   @default("text")  // text | image
  mealType             String   @default("other") // breakfast | lunch | dinner | snack | other
  loggedAt             DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([userId, loggedAt])
  @@index([userId])
}

// -- Food Item (Egyptian Food Database bilingual) ------------

model FoodItem {
  id          String     @id @default(uuid())
  nameEn      String
  nameAr      String
  calories    Float
  protein     Float
  carbs       Float
  fats        Float
  fiber       Float      @default(0)
  servingSize Float      @default(100)
  servingUnit String     @default("g")
  category    String
  isVerified  Boolean    @default(false)

  foodLogs    FoodLog[]
  mealPlans   MealPlan[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([nameEn])
  @@index([nameAr])
  @@index([category])
}

// -- Food Log (Daily logging from food database) -------------

model FoodLog {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId String
  foodItem   FoodItem  @relation(fields: [foodItemId], references: [id])

  servings   Float     @default(1)
  mealType   String    @default("other")
  loggedAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([userId, loggedAt])
  @@index([userId])
}

// -- Water Log -----------------------------------------------

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl  Int
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, loggedAt])
}

// -- Weight Log ----------------------------------------------

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg  Float
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, loggedAt])
}

// -- Meal Plan -----------------------------------------------

model MealPlan {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId String
  foodItem   FoodItem  @relation(fields: [foodItemId], references: [id])

  weekStart  DateTime
  dayOfWeek  Int
  mealType   String
  servings   Float     @default(1)
  isEaten    Boolean   @default(false)

  createdAt  DateTime  @default(now())

  @@index([userId, weekStart])
}

model SponsorProduct {
  id             String   @id @default(uuid())
  name           String
  imageUrl       String
  proteinContent Float
  calorieContent Float
  purchaseUrl    String
  promoCode      String
  createdAt      DateTime @default(now())
}

model Store {
  id                  String   @id @default(uuid())
  storeName           String
  locationCoordinates String
  isOnline            Boolean  @default(false)
  affiliateLink       String
  createdAt           DateTime @default(now())
}
