// ============================================================
//  Prisma Schema -- The Teneen (Egyptian MyFitnessPal)
//  Full schema with all feature models
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Existing Models (Preserved) ─────────────────────────────

model Restaurant {
  id        String           @id @default(uuid())
  name      String           @unique
  category  String
  rating    Float            @default(4.6)
  items     CachedMenuItem[]
  addOns    CachedAddOn[]
  createdAt DateTime         @default(now())
}

model CachedMenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  itemName     String

  caloriesMin  Int
  caloriesMax  Int
  proteinMin   Int
  proteinMax   Int
  carbsMin     Int
  carbsMax     Int
  fatsMin      Int
  fatsMax      Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, itemName])
}

model CachedAddOn {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  addOnName    String
  calories     Int
  protein      Int
  carbs        Int
  fats         Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, addOnName])
}

model Company {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKey])
}

// -- User (Extended with full profile) ----------------------

model User {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  passwordHash     String?
  googleId         String?     @unique
  appleId          String?     @unique

  // Physical profile
  age              Int?
  weightKg         Float?
  heightCm         Float?
  targetWeightKg   Float?      // goal weight set during onboarding
  gender           String?     // male | female
  activityLevel    String      @default("moderate") // sedentary | lightly_active | moderate | very_active
  goal             String      @default("maintain") // lose | maintain | gain

  // Daily goals
  dailyCalorieGoal Int         @default(2000)
  proteinGoal      Int         @default(150)
  carbsGoal        Int         @default(200)
  fatsGoal         Int         @default(65)
  dailyWaterGoalMl Int         @default(2500)

  // App settings
  language         String      @default("en") // en | ar
  isPremium        Boolean     @default(false)
  isActive         Boolean     @default(true)

  // Relations
  mealLogs         MealLog[]
  foodLogs         FoodLog[]
  waterLogs        WaterLog[]
  weightLogs       WeightLog[]
  mealPlans        MealPlan[]
  aiUsageLogs      AiUsageLog[]
  workoutSessions  WorkoutSession[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([email])
}

// -- Meal Log (AI-analyzed restaurant meals) -----------------

model MealLog {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantName       String
  mealName             String
  imageUrl             String?

  calories             Float
  protein              Float
  carbs                Float
  fats                 Float

  ingredientsBreakdown Json
  rawAiResponse        Json?

  source               String   @default("text")  // text | image
  mealType             String   @default("other") // breakfast | lunch | dinner | snack | other
  loggedAt             DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([userId, loggedAt])
  @@index([userId])
}

// -- AI Usage Log (Cost tracking and limits) -----------------

model AiUsageLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  scanType  String   // "camera" or "gallery"
  date      DateTime @db.Date // The day this usage occurred
  createdAt DateTime @default(now())

  @@index([userId, date, scanType])
}

// -- Food Item (Egyptian Food Database bilingual) ------------

model FoodItem {
  id          String     @id @default(uuid())
  nameEn      String
  nameAr      String
  calories    Float
  protein     Float
  carbs       Float
  fats        Float
  fiber       Float      @default(0)
  servingSize Float      @default(100)
  servingUnit String     @default("g")
  category    String
  isVerified  Boolean    @default(false)

  foodLogs    FoodLog[]
  mealPlans   MealPlan[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([nameEn])
  @@index([nameAr])
  @@index([category])
}

// -- Food Log (Daily logging from food database) -------------

model FoodLog {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId String
  foodItem   FoodItem  @relation(fields: [foodItemId], references: [id])

  servings   Float     @default(1)
  mealType   String    @default("other")
  loggedAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([userId, loggedAt])
  @@index([userId])
}

// -- Water Log -----------------------------------------------

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl  Int
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, loggedAt])
}

// -- Weight Log ----------------------------------------------

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg  Float
  loggedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId, loggedAt])
}

// -- Meal Plan -----------------------------------------------

model MealPlan {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId String
  foodItem   FoodItem  @relation(fields: [foodItemId], references: [id])

  weekStart  DateTime
  dayOfWeek  Int
  mealType   String
  servings   Float     @default(1)
  isEaten    Boolean   @default(false)

  createdAt  DateTime  @default(now())

  @@index([userId, weekStart])
}

model SponsorProduct {
  id             String   @id @default(uuid())
  name           String
  imageUrl       String
  proteinContent Float
  calorieContent Float
  purchaseUrl    String
  promoCode      String
  createdAt      DateTime @default(now())
}

model Store {
  id                  String   @id @default(uuid())
  storeName           String
  locationCoordinates String
  isOnline            Boolean  @default(false)
  affiliateLink       String
  createdAt           DateTime @default(now())
}

// ============================================================
//  Gym Tracker & Online Coach Feature
// ============================================================

model Exercise {
  id              String                @id @default(uuid())
  name            String
  description     String?
  muscleGroup     String
  mediaUrl        String?               // Image or Video URL
  mediaType       String?               // "image" or "video"
  alternatives    ExerciseAlternative[] @relation("ExerciseToAlternatives")
  alternativeTo   ExerciseAlternative[] @relation("AlternativeToExercise")
  workoutExercises WorkoutExercise[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model ExerciseAlternative {
  id              String   @id @default(uuid())
  exerciseId      String
  alternativeId   String
  exercise        Exercise @relation("ExerciseToAlternatives", fields: [exerciseId], references: [id], onDelete: Cascade)
  alternative     Exercise @relation("AlternativeToExercise", fields: [alternativeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([exerciseId, alternativeId])
}

model WorkoutSession {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  notes           String?
  exercises       WorkoutExercise[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, startedAt])
}

model WorkoutExercise {
  id              String          @id @default(uuid())
  sessionId       String
  session         WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  order           Int
  sets            ExerciseSet[]
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([sessionId])
  @@index([exerciseId])
}

model ExerciseSet {
  id                String          @id @default(uuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int
  reps              Int?
  weightKg          Float?
  rpe               Int?            // Rate of Perceived Exertion (1-10)
  durationSeconds   Int?            // For timed sets (e.g., planks)
  isCompleted       Boolean         @default(false)
  createdAt         DateTime        @default(now())

  @@index([workoutExerciseId])
}
